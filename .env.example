# NAJ'ELLE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer .env sur Git
# ══════════════════════════════════════════════

# Supabase — récupérer dans Settings > API de votre projet
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Email administrateur (doit correspondre à un compte Supabase Auth)
VITE_ADMIN_EMAIL=admin@najelle.fr
